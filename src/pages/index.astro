---
import LandingLayout from '../layouts/LandingLayout.astro';
import { Image } from 'astro:assets';
import coverImg from './Drone.jpg';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<LandingLayout title="ROS 2 Documentation">

  <h1 class="landing-title">ROS 2 Documentation</h1>
  <p class="landing-subtitle">Zachary Flynn</p>

  <div class="landing-cover-container">
    <Image src={coverImg} alt="ROS 2 Drone Project Cover" class="landing-cover" />
  </div>

  <nav class="toc" aria-label="Table of Contents">

    <div class="toc-chapter">
      <a href={`${base}/preamble`} class="toc-chapter-header">
        <span class="toc-chapter-num">1.</span>
        <span class="toc-chapter-title">Preamble</span>
      </a>
    </div>

    <div class="toc-chapter">
      <a href={`${base}/setup`} class="toc-chapter-header">
        <span class="toc-chapter-num">2.</span>
        <span class="toc-chapter-title">ROS 2 Setup</span>
      </a>
      <div class="toc-links">
        <a href={`${base}/setup#installation`} class="toc-link"><span class="toc-link-num">2.1</span>ROS 2 Installation</a>
        <a href={`${base}/setup#setup-environment`} class="toc-link"><span class="toc-link-num">2.2</span>Setup Development Environment</a>
        <a href={`${base}/setup#updating-packages`} class="toc-link"><span class="toc-link-num">2.3</span>Updating ROS 2 Packages</a>
      </div>
    </div>

    <div class="toc-chapter">
      <a href={`${base}/packages`} class="toc-chapter-header">
        <span class="toc-chapter-num">3.</span>
        <span class="toc-chapter-title">Packages &amp; Nodes</span>
      </a>
      <div class="toc-links">
        <a href={`${base}/packages#creating-packages`} class="toc-link"><span class="toc-link-num">3.1</span>Creating Packages</a>
        <a href={`${base}/packages#building-packages`} class="toc-link"><span class="toc-link-num">3.2</span>Building Packages</a>
        <a href={`${base}/packages#creating-nodes`} class="toc-link"><span class="toc-link-num">3.3</span>Creating Nodes</a>
        <a href={`${base}/packages#running-nodes`} class="toc-link"><span class="toc-link-num">3.4</span>Running Nodes</a>
        <a href={`${base}/packages#introspecting-nodes`} class="toc-link"><span class="toc-link-num">3.5</span>Introspecting Nodes</a>
      </div>
    </div>

    <div class="toc-chapter">
      <a href={`${base}/topics`} class="toc-chapter-header">
        <span class="toc-chapter-num">4.</span>
        <span class="toc-chapter-title">Topics, Publishers &amp; Subscribers</span>
      </a>
      <div class="toc-links">
        <a href={`${base}/topics#publishers`} class="toc-link"><span class="toc-link-num">4.1</span>Publishers</a>
        <a href={`${base}/topics#subscribers`} class="toc-link"><span class="toc-link-num">4.2</span>Subscribers</a>
        <a href={`${base}/topics#introspection`} class="toc-link"><span class="toc-link-num">4.3</span>Introspecting Topics</a>
      </div>
    </div>

    <div class="toc-chapter">
      <a href={`${base}/services`} class="toc-chapter-header">
        <span class="toc-chapter-num">5.</span>
        <span class="toc-chapter-title">Services, Servers &amp; Clients</span>
      </a>
      <div class="toc-links">
        <a href={`${base}/services#servers`} class="toc-link"><span class="toc-link-num">5.1</span>Servers</a>
        <a href={`${base}/services#clients`} class="toc-link"><span class="toc-link-num">5.2</span>Clients</a>
        <a href={`${base}/services#introspection`} class="toc-link"><span class="toc-link-num">5.3</span>Introspecting Services</a>
      </div>
    </div>

    <div class="toc-chapter">
      <a href={`${base}/actions`} class="toc-chapter-header">
        <span class="toc-chapter-num">6.</span>
        <span class="toc-chapter-title">Actions</span>
      </a>
      <div class="toc-links">
        <a href={`${base}/actions#action-servers`} class="toc-link"><span class="toc-link-num">6.1</span>Action Servers</a>
        <a href={`${base}/actions#action-clients`} class="toc-link"><span class="toc-link-num">6.2</span>Action Clients</a>
      </div>
    </div>

    <div class="toc-chapter">
      <a href={`${base}/interfaces`} class="toc-chapter-header">
        <span class="toc-chapter-num">7.</span>
        <span class="toc-chapter-title">Interfaces &amp; Action Types</span>
      </a>
      <div class="toc-links">
        <a href={`${base}/interfaces#data-types`} class="toc-link"><span class="toc-link-num">7.1</span>Common Interface &amp; Action Data Types</a>
        <a href={`${base}/interfaces#interface-structure`} class="toc-link"><span class="toc-link-num">7.2</span>Structure of Interfaces &amp; Actions</a>
        <a href={`${base}/interfaces#using-interfaces`} class="toc-link"><span class="toc-link-num">7.3</span>Using Interfaces &amp; Actions</a>
        <a href={`${base}/interfaces#storing-interfaces`} class="toc-link"><span class="toc-link-num">7.4</span>Creating Packages for Custom Interfaces &amp; Actions</a>
        <a href={`${base}/interfaces#custom-messages`} class="toc-link"><span class="toc-link-num">7.5</span>Custom Message Interfaces</a>
        <a href={`${base}/interfaces#custom-services`} class="toc-link"><span class="toc-link-num">7.6</span>Custom Service Interfaces</a>
        <a href={`${base}/interfaces#custom-actions`} class="toc-link"><span class="toc-link-num">7.7</span>Custom Action Types</a>
        <a href={`${base}/interfaces#vscode-config`} class="toc-link"><span class="toc-link-num">7.8</span>Configuring VS Code for Custom Interfaces</a>
        <a href={`${base}/interfaces#introspecting`} class="toc-link"><span class="toc-link-num">7.9</span>Introspecting Interfaces</a>
      </div>
    </div>

    <div class="toc-chapter">
      <a href={`${base}/parameters`} class="toc-chapter-header">
        <span class="toc-chapter-num">8.</span>
        <span class="toc-chapter-title">Parameters</span>
      </a>
      <div class="toc-links">
        <a href={`${base}/parameters#allowed-parameter-types`} class="toc-link"><span class="toc-link-num">8.1</span>Common Parameter Data Types</a>
        <a href={`${base}/parameters#defining-loading-parameters`} class="toc-link"><span class="toc-link-num">8.2</span>Defining &amp; Using Parameters</a>
        <a href={`${base}/parameters#introspecting-parameters`} class="toc-link"><span class="toc-link-num">8.3</span>Introspecting Parameters</a>
      </div>
    </div>

    <div class="toc-chapter">
      <a href={`${base}/launch`} class="toc-chapter-header">
        <span class="toc-chapter-num">9.</span>
        <span class="toc-chapter-title">Launch Files</span>
      </a>
      <div class="toc-links">
        <a href={`${base}/launch#creating-launch-files`} class="toc-link"><span class="toc-link-num">9.1</span>Creating Launch Files</a>
        <a href={`${base}/launch#python-launch-files`} class="toc-link"><span class="toc-link-num">9.2</span>Python Launch Files</a>
        <a href={`${base}/launch#yaml-launch-files`} class="toc-link"><span class="toc-link-num">9.3</span>YAML Launch Files</a>
        <a href={`${base}/launch#xml-launch-files`} class="toc-link"><span class="toc-link-num">9.4</span>XML Launch Files</a>
        <a href={`${base}/launch#configuring-running-launch-files`} class="toc-link"><span class="toc-link-num">9.5</span>Configuring Launch Executables</a>
        <a href={`${base}/launch#running-launch-scripts`} class="toc-link"><span class="toc-link-num">9.6</span>Running Launch Scripts</a>
      </div>
    </div>

  </nav>

</LandingLayout>

<!-- your existing <style> block unchanged -->