---
import LandingLayout from '../layouts/LandingLayout.astro';
// Import Astro's optimized image handling component
import { Image } from 'astro:assets';
// Import your local image relatively from the current directory
import coverImg from './Drone.jpg'; 
---

<LandingLayout title="ROS 2 Documentation">

  <h1 class="landing-title">ROS 2 Documentation</h1>
  <p class="landing-subtitle">Zachary Flynn</p>

  <div class="landing-cover-container">
    {/* Using Astro's <Image /> component automatically optimizes Drone.jpg */}
    <Image 
      src={coverImg} 
      alt="ROS 2 Drone Project Cover" 
      class="landing-cover" 
    />
  </div>

  <nav class="toc" aria-label="Table of Contents">

    {/* ── CHAPTER 1 ── */}
    <div class="toc-chapter">
      <a href="/preamble" class="toc-chapter-header">
        <span class="toc-chapter-num">1.</span>
        <span class="toc-chapter-title">Preamble</span>
      </a>
    </div>

    {/* ── CHAPTER 2 ── */}
