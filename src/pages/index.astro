<style>
  .landing-cover-container {
    width: 100%;
    margin-bottom: 2.5rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .landing-cover-container {
    width: 100%;
    /* 1. Matches standard documentation container limits */
    max-width: 1000px; 
    /* 2. Centers the container if the screen expands wider than 720px */
    margin: 0 auto 2.5rem auto; 
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .landing-cover {
    width: 100%;
    height: auto;
    /* 3. Drop or adjust this if you want to see the full vertical height of the drone */
    max-height: 600px; 
    object-fit: cover;
    display: block;
  }

</style>