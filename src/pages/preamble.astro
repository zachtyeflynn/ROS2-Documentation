---
import DocLayout from '../layouts/DocLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';

// Key:
//   ph-generic  → bashGeneric   RGB(208,26,20)    red
//   ph-var      → variables     RGB(0,75,0)       dark green
//   ph-type     → types         Blue
//   ph-class    → classes       Orange
//   ph-fn       → functions     Orchid
//   ph-exec     → executables   RGB(255,102,178)  pink
//   ph-file     → fileNames     NavyBlue
//   ph-dir      --> directories   Green

// ── Preamble ─────────────────────────────────────────────────────────────────
const xmlPlaceholderCode =
`[generic]
[directory]
[executable]
[file]
[variable]
[class]
[function]
[type]`;

const xmlPlaceholderCustom =
`<span class="ph-generic">[generic]</span>
<span class="ph-dir">[directory]</span>
<span class="ph-exec">[executable]</span>
<span class="ph-file">[file_name]</span>
<span class="ph-var">[variable]</span>
<span class="ph-class">[class]</span>
<span class="ph-fn">[function]</span>
<span class="ph-type">[type]</span>`;

const documentationLinks = [
  { name: "ROS 2 Jazzy Jalisco", url: "https://docs.ros.org/en/jazzy/index.html" },
  { name: "C++ ROS Client Library (rclcpp)", url: "https://docs.ros.org/en/jazzy/p/rclcpp/generated/index.html" },
  { name: "Python ROS Client Library (rclpy)", url: "https://docs.ros.org/en/iron/p/rclpy/" },
  { name: "Eigen3", url: "https://libeigen.gitlab.io/eigen/docs-3.4/" },
  { name: "Pinocchio", url: "https://docs.ros.org/en/humble/p/pinocchio/" },
  { name: "MoveIt 2", url: "https://moveit.picknik.ai/main/index.html" },
  { name: "Gazebo", url: "https://gazebosim.org/docs/latest/getstarted/" },
  { name: "ros_2_control", url: "https://control.ros.org/rolling/index.html" },
  { name: "RViz2", url: "https://docs.ros.org/en/jazzy/Visualization/Rviz.html" },
  { name: "Colcon / Build Tools", url: "https://docs.ros.org/en/jazzy/Tutorials/Colcon-Tutorial.html" },
  { name: "Drake", url: "https://drake.mit.edu/" },
  { name: "MuJoCo", url: "https://mujoco.readthedocs.io/en/stable/overview.html" }
];
---

<DocLayout title="Preamble" activeSection="preamble">

  <h1 class="doc-title">Preamble</h1>
  <p class="doc-subtitle">Chapter 1</p>

  <h2 class="subsection-heading">ROS 2 Version</h2>
  <p>This guide was created for ROS 2 Jazzy Jalisco on Ubuntu 24.04. As of May 2026, Jazzy Jalisco is no longer the most up to date long term support (LTS) version of ROS 2, succeeded by Lyrical Luth. LTS of Jazzy Jalisco will continue until May 2029. For now, Jazzy remains one of the most commonly and stable LTS version of ROS 2. This guide will eventually be updated for Lyrical once adoption is widespread.</p>
  <p>For more on ROS 2 distributions, please refer <a href="https://docs.ros.org/en/jazzy/Releases.html" target="_blank" rel="noopener noreferrer">here</a>.</p>

  <h2 class="subsection-heading">Keyword Placeholders Notation</h2>
  <p>This documentation uses a highlighting system for placeholder keywords within its codeblocks. These placeholders are intended to be replaced by the user when copying over to their code base. The highlighting is intended to provide clarity over what data types these placeholders are.</p>

  <CodeBlock code={xmlPlaceholderCode} lang="text" customHtml={xmlPlaceholderCustom} showLegend={false} defaultTab="custom" />

  <p>Most codeblocks have a toggle to change between typical, language-specific syntax highlighting and the keyword placeholder highlighting.</p>

  <h2 class="subsection-heading">Further Documentation</h2>
  <div class="table-container">
    <table class="doc-table">
      <thead>
        <tr>
          <th>Documentation</th>
          <th>Link</th>
        </tr>
      </thead>
      <tbody>
        {documentationLinks.map((doc) => (
          <tr>
            <td><strong>{doc.name}</strong></td>
            <td><a href={doc.url} target="_blank" rel="noopener noreferrer">{doc.url}</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2 class="subsection-heading">Acknowledgments</h2>
  <p>Some of the code and other elements of this guide was adapted from the course COMP 514: Applied Robotics at McGill University by Professor Hsiu-Chin Lin and the Udemy course ROS 2 for Beginners by Edouard Renard.</p>
  <p>Title cover image by Jeff Robertson - Associated Press.</p>

</DocLayout>

<style>
  /* Translated from LaTeX tabularray constraints:
    width=10in, \footnotesize, vlines, hlines, 
    X[c,m] (centered horizontally/vertically), 
    row{1}={font=\bfseries, bg=gray!10}, hline{2}={1.2pt} 
  */

  .table-container {
    display: flex;
    justify-content: center; /* Centers the 5.5in table */
    overflow-x: auto;
    margin: 2rem 0;
  }

  .doc-table {
    width: 100%;
    max-width: 10.5in; /* Maps to width=5.5in */
    border-collapse: collapse;
    font-size: 0.85rem; /* Maps roughly to \footnotesize */
    border: 1px solid #000000; /* Outer bounding box */
    color: #000000; 
  }

  /* Target all cells to apply vlines, hlines, and X[c,m] alignment */
  .doc-table th, 
  .doc-table td {
    border: 1px solid #000000; /* Maps to vlines, hlines */
    padding: 8px 12px; /* Maps to rowsep = 4pt + standard colsep */
    text-align: center; /* Maps to X[c] (horizontal center) */
    vertical-align: middle; /* Maps to X[m] (vertical middle) */
    word-wrap: break-word; /* Allows flexible column wrapping like X */
  }

  /* Header Styling mapped to row{1} and hline{2} */
  .doc-table th {
    background-color: #e7e7e7; /* Maps to bg=gray!10 */
    font-weight: bold; /* Maps to font=\bfseries */
    border-bottom: 2px solid #000000; /* Maps to hline{2} = {1.2pt} */
  }

  /* Dark mode overrides if needed by your Astro theme */
  :global([data-theme="dark"]) .doc-table,
  :global([data-theme="dark"]) .doc-table th,
  :global([data-theme="dark"]) .doc-table td {
    border-color: #949494;
    color: #a6adc8;
  }
  :global([data-theme="dark"]) .doc-table th {
    background-color: #222230;
    border-bottom-color: #949494;
  }
</style>