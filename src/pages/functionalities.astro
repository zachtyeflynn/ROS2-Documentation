const cppEigenMapFromArrayVector = `// **** Declaring and assigning a new variable **** //
// Fixed size Eigen::Vector (e.g. Vector3d) - C array must have at least 3 entries
Eigen::Map<Eigen::Vector3d> [eigen_variable_vector3d]([c_array_vector]);
// Dynamic Eigen::Vector
Eigen::Map<Eigen::VectorXd> [eigen_variable_vectorXd]([c_array_vector], sizeof([c_array_vector]));

// **** Assigning an existing variable **** //
// Previously declared, fixed size Eigen::Vector (e.g. Vector3d)
[eigen_variable_vector3d] = Eigen::Map<Eigen::Vector3d>([c_array_vector]);
`;

