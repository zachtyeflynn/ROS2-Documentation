const cppPinocchioDynamics = `#include <pinocchio/algorithm/crba.hpp>
#include <pinocchio/algorithm/rnea.hpp>

// 1. Joint Space Inertia Matrix M(q) via Composite Rigid Body Algorithm
Eigen::MatrixXd [M_matrix]([pinocchio_model].nv, [pinocchio_model].nv);
[M_matrix].setZero();
pinocchio::crba([pinocchio_model], [pinocchio_data], [joint_configuration_q]);
// Fill the symmetric upper/lower triangulation structures safely
[M_matrix].triangularView<Eigen::Lower>() = [pinocchio_data].M.triangularView<Eigen::Lower>();

// 2. Non-linear effects vector h(q, v) = C(q,v)v + g(q) via Recursive Newton-Euler Algorithm
Eigen::VectorXd [joint_velocity_v] = Eigen::VectorXd::Zero([pinocchio_model].nv);
Eigen::VectorXd [joint_acceleration_a] = Eigen::VectorXd::Zero([pinocchio_model].nv);
Eigen::VectorXd [h_vector] = pinocchio::rnea([pinocchio_model], [pinocchio_data], [joint_configuration_q], [joint_velocity_v], [joint_acceleration_a]);
`;

