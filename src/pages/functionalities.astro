const cppPinocchioComputeAll = `#include <pinocchio/algorithm/compute-all-terms.hpp>

// Create acceleration vector set to zero for static/quasi-static checks
Eigen::VectorXd [joint_velocity_v] = Eigen::VectorXd::Zero([pinocchio_model].nv);
Eigen::VectorXd [joint_acceleration_a] = Eigen::VectorXd::Zero([pinocchio_model].nv);

// Computes FK, Jacobians, M(q), and h(q,v) simultaneously in a single pass
pinocchio::computeAllTerms([pinocchio_model], [pinocchio_data], [joint_configuration_q], [joint_velocity_v]);

// Results are immediately accessible inside data cache structures:
// M(q) -> pinocchio_data.M
// h(q,v) -> pinocchio_data.nle
// Jacobians -> pinocchio_data.J
// Placements -> pinocchio_data.oMi
`;

