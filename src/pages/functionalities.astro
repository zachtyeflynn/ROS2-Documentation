const cppPinocchioIK = `#include <pinocchio/algorithm/joint-configuration.hpp>

// Numerical optimization settings
double [eps] = 1e-4;
int [max_iters] = 1000;
double [damp] = 1e-6;

Eigen::VectorXd [q_init] = pinocchio::neutral([pinocchio_model]);
Eigen::VectorXd [q_result] = [q_init];

// Iterative IK routine utilizing Pseudo-Inverse Jacobian steps
for (int i = 0; i < [max_iters]; ++i) {
  pinocchio::forwardKinematics([pinocchio_model], [pinocchio_data], [q_result]);
  const pinocchio::SE3 [dMi] = [target_placement].actInv([pinocchio_data].oMi[[joint_id]]);
  const pinocchio::Motion [err] = pinocchio::log6([dMi]);
  
  if ([err].toVector().norm() < [eps]) break;

  Eigen::MatrixXd [J](6, [pinocchio_model].nv); [J].setZero();
  pinocchio::computeJointJacobian([pinocchio_model], [pinocchio_data], [q_result], [joint_id], [J]);
  
  Eigen::MatrixXd [JJt] = [J] * [J].transpose();
  [JJt].diagonal().array() += [damp];
  Eigen::VectorXd [v] = [J].transpose() * [JJt].ldlt().solve([err].toVector());
  [q_result] = pinocchio::integrate([pinocchio_model], [q_result], [v]);
}
`;

