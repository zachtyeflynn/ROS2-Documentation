const pyFullStructCode = 
`from launch import LaunchDescription
from launch.actions import DeclareLaunchArgument, IncludeLaunchDescription
from launch.launch_description_sources import PythonLaunchDescriptionSource
from launch.launch_description_sources import AnyLaunchDescriptionSource
from launch.substitutions import LaunchConfiguration, PathJoinSubstitution
from launch_ros.actions import Node
from launch_ros.substitutions import FindPackageShare

def generate_launch_description():

    # Arguments
    [return_argument_name] = DeclareLaunchArgument("[argument_name]", default_value="[argument_default_value]")
    [argument_variable_name] = LaunchConfiguration("[argument_name]")
    # ...
    
    # Launching nodes
    [node_variable_name] = Node(
        package="[package_name]",
        executable="[executable_node_name]",
        name="[node_name]",
        parameters=[
            {"[parameter_name_1]": [value_1],
            "[parameter_name_2]": [argument_variable_name], # Example: argument as node parameter
            # ...
            }
        ],
        ros_arguments=["[ROS_args]", "[...]"]
    )
    # ...

    # Other launch files
    [launch_pkg] = FindPackageShare("[launch_package_name]")
    [launch_file] = PathJoinSubstitution([[launch_pkg] , "launch", "[launch_file_name].launch.[extension_type]"])
    [return_launch_file] = IncludeLaunchDescription(
        PythonLaunchDescriptionSource([launch_file]),
        launch_arguments={
            "[argument_name_1]": [value_1],
            "[argument_name_2]": [value_2],
            # ...
        }.items()
    )
    
    # IMPORTANT: return ALL ARGUMENTS, NODES and OTHER LAUNCH FILES
    return LaunchDescription([
        [return_argument_name], [node_variable_name], [return_launch_file]
    ])`;

