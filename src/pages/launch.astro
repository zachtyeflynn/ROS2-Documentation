// --- Python Launch Files: Full Structure ---
const pyFullLaunchCode = 
`from launch import LaunchDescription
from launch.actions import DeclareLaunchArgument, IncludeLaunchDescription
from launch.launch_description_sources import PythonLaunchDescriptionSource
from launch.launch_description_sources import AnyLaunchDescriptionSource
from launch.substitutions import LaunchConfiguration, PathJoinSubstitution
from launch_ros.actions import Node
from launch_ros.substitutions import FindPackageShare

def generate_launch_description():

    # Arguments
    [return_argument_name] = DeclareLaunchArgument("[argument_name]", default_value="[argument_default_value]")
    [argument_variable_name] = LaunchConfiguration("[argument_name]")
    # ...
    
    # Launching nodes
    [node_variable_name] = Node(
        package="[package_name]",
        executable="[executable_node_name]",
        name="[node_name]",
        parameters=[
            {"[parameter_name_1]": [value_1],
            "[parameter_name_2]": [argument_variable_name], # Example: argument as node parameter
            # ...
            }
        ],
        ros_arguments=["[ROS_args]", "[...]"]
    )
    # ...

    # Other launch files
    [launch_pkg] = FindPackageShare("[launch_package_name]")
    [launch_file] = PathJoinSubstitution([[launch_pkg] , "launch", "[launch_file_name].launch.[extension_type]"])
    [return_launch_file] = IncludeLaunchDescription(
        PythonLaunchDescriptionSource([launch_file]),
        launch_arguments={
            "[argument_name_1]": [value_1],
            "[argument_name_2]": [value_2],
            # ...
        }.items()
    )
    
    # IMPORTANT: return ALL ARGUMENTS, NODES and OTHER LAUNCH FILES
    return LaunchDescription([
        [return_argument_name], [node_variable_name], [return_launch_file]
    ])`;

const pyFullLaunchCustom = 
`from launch import LaunchDescription
from launch.actions import DeclareLaunchArgument, IncludeLaunchDescription
from launch.launch_description_sources import PythonLaunchDescriptionSource
from launch.launch_description_sources import AnyLaunchDescriptionSource
from launch.substitutions import LaunchConfiguration, PathJoinSubstitution
from launch_ros.actions import Node
from launch_ros.substitutions import FindPackageShare

def generate_launch_description():

    # Arguments
    <span class="ph-var">[return_argument_name]</span> = DeclareLaunchArgument("<span class="ph-generic">[argument_name]</span>", default_value="<span class="ph-generic">[argument_default_value]</span>")
    <span class="ph-var">[argument_variable_name]</span> = LaunchConfiguration("<span class="ph-generic">[argument_name]</span>")
    # ...
    
    # Launching nodes
    <span class="ph-var">[node_variable_name]</span> = Node(
        package="<span class="ph-generic">[package_name]</span>",
        executable="<span class="ph-exec">[executable_node_name]</span>",
        name="<span class="ph-generic">[node_name]</span>",
        parameters=[
            {"<span class="ph-generic">[parameter_name_1]</span>": <span class="ph-generic">[value_1]</span>,
            "<span class="ph-generic">[parameter_name_2]</span>": <span class="ph-var">[argument_variable_name]</span>, # Example: argument as node parameter
            # ...
            }
        ],
        ros_arguments=["<span class="ph-generic">[ROS_args]</span>", "<span class="ph-generic">[...]</span>"]
    )
    # ...

    # Other launch files
    <span class="ph-var">[launch_pkg]</span> = FindPackageShare("<span class="ph-generic">[launch_package_name]</span>")
    <span class="ph-var">[launch_file]</span> = PathJoinSubstitution([<span class="ph-var">[launch_pkg]</span> , "launch", "<span class="ph-file">[launch_file_name]</span>.launch.<span class="ph-generic">[extension_type]</span>"])
    <span class="ph-var">[return_launch_file]</span> = IncludeLaunchDescription(
        PythonLaunchDescriptionSource(<span class="ph-var">[launch_file]</span>),
        launch_arguments={
            "<span class="ph-generic">[argument_name_1]</span>": <span class="ph-generic">[value_1]</span>,
            "<span class="ph-generic">[argument_name_2]</span>": <span class="ph-generic">[value_2]</span>,
            # ...
        }.items()
    )
    
    # IMPORTANT: return ALL ARGUMENTS, NODES and OTHER LAUNCH FILES
    return LaunchDescription([
        <span class="ph-var">[return_argument_name]</span>, <span class="ph-var">[node_variable_name]</span>, <span class="ph-var">[return_launch_file]</span>
    ])`;

// --- 4.6 YAML Launch Files ---
const yamlFullLaunchCode = 
`launch:

    # Arguments
    - arg:
        name: [argument_name]
        default: "[argument_default_value]"
    # ...

    # Launching nodes
    - node:
    pkg: "[package_name]"
    exec: "[executable_node_name]"
    name: "[node_name]"
    parameters:
        - name: [parameter_name_1]
          value: "[value_1]"
        - name: [parameter_name_2]
          value:  "$(var [argument_name])" # Example: argument as node parameter
        # ...
    args: "--ros-args [ROS_args] [...]"
    # ...

    # Other launch files
    - include
        file: "$(path-join $(find-pkg-share [other_package_name]) launch [other_launch_file].launch.[extension_type])"
        arg:
            - name: [argument_name_1]
              value: "[argument_value_1]"
            - name: [argument_name_2]
              value: "[argument_value_2]"
              # ...`;

