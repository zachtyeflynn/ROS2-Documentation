const pyExecutionLoopCode = 
`#import asyncio

# ...

async def [action_accepted_callback_function](self, goal):

        # Define variables for the feedback and results of the action
        feedback = [action_type].Feedback()
        result = [action_type].Result()

        # Execution loop (equivalent to your while loop)
        while [execution_conditions]:

            # Perform checks on process, provide feedback to client, etc.
            feedback.[feedback_variable_1] = ...
            feedback.[feedback_variable_2] = ...
            # ...
            goal.publish_feedback(feedback)

            # Check and handle for cancellation
            if goal.is_cancel_requested():
            
                # Modify result.[result_variable_1] ...
                goal.canceled() # Set this only if you can truly cancel action
                return result
            
            # Abort process if needed
            if [abort_conditions]:

                # Modify result.[result_variable_1] ...
                goal.abort()
                return result

            await asyncio.sleep(dt)

        # Once goal is acheived, return results
        result.[result_variable_1] = ...
        result.[result_variable_2] = ...

        return result`;

