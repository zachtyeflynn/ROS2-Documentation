const cppActionServerInitCode = 
`// Extra header for action servers
#include <rclcpp_action/rclcpp_action.hpp>
#include <thread>

public:

    // Constructor
    [node_class_name]() : Node("[node_name]"") {

        // Initialize action server attribute
        [action_server_variable_name] = rclcpp_action::create_server${'<'}[action_type]>(this,
            "[action_name]",
            std::bind(&[node_class_name]::[action_request_callback_function], this, std::placeholders::_1, std::placeholders::_2),
            std::bind(&[node_class_name]::[action_cancel_callback_function], this, std::placeholders::_1),
            std::bind(&[node_class_name]::[action_accepted_callback_function], this, std::placeholders::_1));

    }

private:

    // Declare a pointer to the action server attribute
    rclcpp_action::Server${'<'}[action_type]>::SharedPtr [action_server_variable_name];`;

