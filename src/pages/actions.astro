const cppExecutionLoopCode = 
`void [action_accepted_callback_function](const std::shared_ptr${'<'}rclcpp_action::ServerGoalHandle${'<'}[action_type]>> goal) {

    // Start execution on a seperate thread
    std::thread{
        std::bind(&[node_class_name]::[handle_execution_function], this, std::placeholders::_1), goal  }.detach();
}

void [handle_execution_function](const std::shared_ptr${'<'}rclcpp_action::ServerGoalHandle${'<'}[action_type]>> goal) {

    // Define variables for the feedback and result of the action
    auto result = std::make_shared${'<'}[action_type]::Result>();
    auto feedback = std::make_shared${'<'}[action_type]::Feedback>();

    // While loop for execution based on the completion criteria
    while ([execution_conditions]) {

        // Perform checks on process, provide feedback to client, etc.
        feedback->[feedback_variable_1] = ...
        feedback->[feedback_variable_2] = ...
        // ...
        goal->publish_feedback(feedback)

        // Check and handle for cancellation
        if (goal->is_canceling()) {

            // Modify result.[result_variable_1] ...
            goal->canceled(result);
            return;
                
        }

        // Abort process if needed
        if (abort_conditions) {

            // Modify result.[result_variable_1] ...
            goal->abort(result);
            return;

        }
    }

    // Once goal is acheived, return results using pointer
    // Modify result.[result_variable_1] ...
    goal->succeed(result);
}`;

const cppExecutionLoopCustom = 
`void <span class="ph-fn">[action_accepted_callback_function]</span>(const std::shared_ptr&lt;rclcpp_action::ServerGoalHandle&lt;<span class="ph-type">[action_type]</span>&gt;&gt; goal) {

    // Start execution on a seperate thread
    std::thread{
        std::bind(&amp;<span class="ph-class">[node_class_name]</span>::<span class="ph-fn">[handle_execution_function]</span>, this, std::placeholders::_1), goal  }.detach();
}

void <span class="ph-fn">[handle_execution_function]</span>(const std::shared_ptr&lt;rclcpp_action::ServerGoalHandle&lt;<span class="ph-type">[action_type]</span>&gt;&gt; goal) {

    // Define variables for the feedback and result of the action
    auto result = std::make_shared&lt;<span class="ph-type">[action_type]</span>::Result&gt;();
    auto feedback = std::make_shared&lt;<span class="ph-type">[action_type]</span>::Feedback&gt;();

    // While loop for execution based on the completion criteria
    while ([execution_conditions]) {

        // Perform checks on process, provide feedback to client, etc.
        feedback-&gt;[feedback_variable_1] = ...
        feedback-&gt;[feedback_variable_2] = ...
        // ...
        goal-&gt;publish_feedback(feedback)

        // Check and handle for cancellation
        if (goal-&gt;is_canceling()) {

            // Modify result.[result_variable_1] ...
            goal-&gt;canceled(result);
            return;
                
        }

        // Abort process if needed
        if (abort_conditions) {

            // Modify result.[result_variable_1] ...
            goal-&gt;abort(result);
            return;

        }
    }

    // Once goal is acheived, return results using pointer
    // Modify result.[result_variable_1] ...
    goal-&gt;succeed(result);
}`;

