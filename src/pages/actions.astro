// --- 4.1.1 Creating Action Servers ---
const pyActionServerInitCode = 
`# Extra imports for action servers
from rclpy.action import ActionServer
from rclpy.action import CancelResponse, GoalResponse

# In constructor
self.[action_server_variable_name] = ActionServer(
            self,
            [action_type],
            "[action_name]",
            execute_callback=self.[action_accepted_callback_function],
            goal_callback=self.[action_request_callback_function],
            cancel_callback=self.[action_cancel_callback_function])`;

const pyActionServerInitCustom = 
`# Extra imports for action servers
